{
  "name": "whatsapp-agent",
  "version": "1.0.0",
  "description": "AI agent that connects to WhatsApp via whatsapp-web.js, orchestrates analysis with Agno, and summarizes group discussions",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "echo 'No build step required for Node.js'",
    "logs": "node src/index.js 2>&1 | tee whatsapp-agent.log"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "whatsapp-web.js",
    "agno",
    "summarization",
    "nlp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.28.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
