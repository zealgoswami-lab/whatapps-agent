# ============================================================================
# WHATSAPP AGENT ENVIRONMENT VARIABLES
# ============================================================================

# Node.js Server
PORT=3000
LOG_LEVEL=info

# Python Service Configuration
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_PORT=8000

# Bailey WhatsApp Configuration
BAILEY_SESSION_PATH=./auth_info_baileys
BAILEY_RECONNECT_RETRIES=5
BAILEY_MESSAGE_TIMEOUT=30000
BAILEY_RATE_LIMIT_MS=100

# Message Processing
MESSAGE_QUEUE_PROCESSING_DELAY=100
MESSAGE_MAX_RETRIES=3
SUMMARIZATION_MIN_LENGTH=100
SUMMARIZATION_MAX_LENGTH=150

# Alerts
ALERT_COOLDOWN_MINUTES=5
ALERT_ENABLED=true

# Logging
LOG_DIRECTORY=./logs
LOG_MAX_FILES=5
LOG_MAX_SIZE_MB=5

# Optional: GPU Usage for Summarizer
USE_GPU=0

# Optional: Model Configuration
SUMMARIZER_MODEL=facebook/bart-large-cnn
MENTION_DETECTOR_MODEL=default

# Optional: Integrations (Phase 3)
# Google Calendar Integration
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_CALENDAR_ID=

# Notion Integration
NOTION_ENABLED=false
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Trello Integration
TRELLO_ENABLED=false
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_BOARD_ID=

# Slack/Telegram Notifications (Alternative to WhatsApp)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
